# =============================
# PokeAndre — Variáveis de Ambiente
# =============================
# Copie este arquivo para .env e preencha os valores.

# --- Fontes de Dados ---
API_BASE_LINK=https://pokeapi.co/api/v2/pokemon
CSV_BASE_LINK=https://gist.githubusercontent.com/armgilles/194bcff35001e7eb53a2a8b441e8b2c6/raw/92200bc0a673d5ce2110aaad4544ed6c4010f687/pokemon.csv

# --- Desenvolvimento ---
# Limite de Pokémon para testes (comentar ou remover para processar todos)
POKEMON_LIMIT=20

# --- PostgreSQL ---
POSTGRES_HOST=localhost
POSTGRES_PORT=5432
POSTGRES_DB=pokeandre
POSTGRES_USER=pokeandre
POSTGRES_PASSWORD=pokeandre
